{
  "manifest_version": 2,
  "name": "Tab Lock",
  "version": "1.2.1",
  "description": "Lock browser tabs behind biometric authentication",
  "icons": {
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "contextMenus",
    "webNavigation",
    "activeTab",
    "notifications",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["lock-screen.css"],
      "run_at": "document_start"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": "icons/locked.svg",
    "default_title": "Tab Lock"
  },
  "content_security_policy": "default-src 'self'; style-src 'self' 'unsafe-inline'",
  "browser_specific_settings": {
    "gecko": {
      "id": "tablock@zen.example",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}