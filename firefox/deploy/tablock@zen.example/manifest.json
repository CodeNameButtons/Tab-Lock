{
  "manifest_version": 2,
  "name": "Tab Lock",
  "version": "1.0.1",
  "description": "Lock browser tabs with Windows Hello passkeys",
  "icons": {
    "48": "icons/locked.svg",
    "96": "icons/locked.svg"
  },
  "permissions": [
    "tabs",
    "storage",
    "contextMenus",
    "webNavigation",
    "activeTab",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["lock-screen.css"],
      "run_at": "document_start"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": "icons/locked.svg",
    "default_title": "Tab Lock"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tablock@zen.example",
      "strict_min_version": "112.0"
    }
  }
}